-- Andmebaasi loomine
CREATE DATABASE companydb;
USE companydb;

-- Logitabel
CREATE TABLE AuditLog (
id INT IDENTITY(1,1) PRIMARY KEY,
event_time DATETIME DEFAULT GETDATE(),
action_type VARCHAR(50),
table_name VARCHAR(50),
description_ VARCHAR(500),
user_ VARCHAR(100)
);

-- Osakondade tabel
CREATE TABLE Departments (
id INT IDENTITY(1,1) PRIMARY KEY,
department_name VARCHAR(100)
);

-- Töötajate tabel
CREATE TABLE Employees (
id INT IDENTITY(1,1) PRIMARY KEY,
name VARCHAR(100),
salary DECIMAL(10,2),
department_id INT,
CONSTRAINT FK_Employees_Departments
FOREIGN KEY (department_id)
REFERENCES Departments(id)
);

-- MINU TRIGGER: INSERT Employees
CREATE TRIGGER Employees_Insert
ON Employees
AFTER INSERT
AS
BEGIN
INSERT INTO AuditLog (
action_type,
table_name,
description_,
user_
)
SELECT
'INSERT',
'Employees',
CONCAT('Lisati töötaja: ',i.name,', palk ',i.salary,', osakond ',d.department_name),
SYSTEM_USER
FROM inserted i
JOIN Departments d
ON i.department_id = d.id;
END;

-- MINU TRIGGER: DELETE Employees
CREATE TRIGGER Employees_Delete
ON Employees
AFTER DELETE
AS
BEGIN
INSERT INTO AuditLog (
action_type,
table_name,
description_,
user_
)
SELECT
'DELETE',
'Employees',
CONCAT('Kustutati töötaja: ',dlt.name,', palk ',dlt.salary,', osakond ',dep.department_name),
SYSTEM_USER
FROM deleted dlt
JOIN Departments dep
ON dlt.department_id = dep.id;
END;

-- MINU TRIGGER: UPDATE Employees 
CREATE TRIGGER Employees_Update
ON Employees
AFTER UPDATE
AS
BEGIN
INSERT INTO AuditLog (
action_type,
table_name,
description_,
user_
)
SELECT
'UPDATE',
'Employees',
CONCAT('Töötaja andmeid muudeti: Vana -> ',d.name,', palk ',d.salary,', osakond ',oldDep.department_name,' | Uus -> ',i.name,', palk ',
i.salary,', osakond ',newDep.department_name),
SYSTEM_USER
FROM deleted d
JOIN inserted i
ON d.id = i.id
JOIN Departments oldDep
ON d.department_id = oldDep.id
JOIN Departments newDep
ON i.department_id = newDep.id;
END;

