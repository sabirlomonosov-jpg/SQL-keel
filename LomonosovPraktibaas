CREATE PROCEDURE LisaFirma
    @firmanimi VARCHAR(20),
    @aadress VARCHAR(20),
    @telefon VARCHAR(20)
AS
BEGIN
    INSERT INTO firma (firmanimi, aadress, telefon)
    VALUES (@firmanimi, @aadress, @telefon);
END;

