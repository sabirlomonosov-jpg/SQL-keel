--select kuvab ainult 2 vergu tabelist
SELECT tootja, telefonMudel AS mudel FROM telefon

--sorteerimine
--ASC kasvavas jarjekorras
SELECT tootja, telefonMudel AS mudel, hind
FROM telefon
ORDER BY hind
--DESC kahanevas jarjekorras
SELECT tootja, telefonMudel AS mudel, hind
FROM telefon
ORDER BY hind DESC

--võrdlemine >, <, =, >=, <=
SELECT telefonMudel, hind
FROM telefon
WHERE hind > 25 --leiab mudelid hinnaga suurem kui 25
ORDER BY hind

--leia mudelid vahemikus 10-15 euro
SELECT telefonMudel, hind
FROM telefon
WHERE hind BETWEEN 10 and 15
ORDER BY hind
--sama paring ilma BETWEEN
SELECT telefonMudel, hind
FROM telefon
WHERE 10 <= hind and hind < 15
ORDER BY hind

--distinct !? naitab ainult 1 kordus
SELECT DISTINCT oSystem FROM telefon

--vordlamine tekstiga LIKE
SELECT tootja, telefonMudel
FROM telefon
WHERE tootja LIKE 'Lenovo'

--IN kuvab vastavus looetelus
SELECT tootja, telefonMudel
FROM telefon
WHERE tootja IN ('Lenovo','Samsung','ZTE')

--saama paring ilma IN
SELECT tootja, telefonMudel
FROM telefon
WHERE tootja LIKE 'Lenovo' OR tootja LIKE 'Samsung' OR tootja LIKE 'ZTE'

--leia mudeli mis algavad S tahega
SELECT tootja, telefonMudel
FROM telefon
WHERE telefonMudel LIKE 'S%'

--sisaldab >ś taht '%S%'

--argegaat funktsioonid: AVG, MAX, MIN, SUM, COUNT
--keskmine valjastamise aasta
SELECT AVG(v_aasta) AS keskmine_aasta
FROM telefon

--telefonide ulkogus
SELECT Count(*) AS uldkogus
FROM telefon

--keeruline variant
SELECT tootja, Count(*) AS uldkogus
FROM telefon
GROUP BY tootja

--top 6
SELECT top 6 tootja, hind
FROM telefon
ORDER BY tootja DESC
